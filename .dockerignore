# ============================================================
# .dockerignore — Keeps Docker build contexts lean and fast
# ============================================================

# Version control
.git
.gitignore
.gitattributes
.github

# Infrastructure (not needed in service containers)
infra/
argocd/
terraform/
scripts/
resources/

# Documentation
*.md
docs/
README*

# Local development artifacts
docker-compose.yml
docker-compose.*.yml
Makefile
*.log
tmp/
bin/
dist/
.cache/

# Test & coverage artifacts
**/*_test.go
test-reports/
coverage.out
lint-report.txt
sonar-project.properties

# CI/CD artifacts
.prettierignore
spark-values.yaml
patch.json

# Build outputs
**/*.exe
**/*.dll
**/*.so

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.envrc

# OS
.DS_Store
Thumbs.db
ehthumbs.db
